# ============================================================
# arXiv Paper Tracker 环境变量配置
# 复制此文件为 .env 并填入您的配置
# ============================================================

# LLM API Keys（至少配置一个）
# ------------------------------------------------------------

# Groq API Key（免费，推荐）
# 获取地址: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Anthropic API Key（可选）
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# 如果使用代理服务，配置 base URL
# ANTHROPIC_BASE_URL=https://your-proxy-url.com

# OpenAI API Key（可选）
# 获取地址: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# 消息推送凭证（可选）
# ------------------------------------------------------------

# 飞书机器人 Webhook URL
# 获取方式: 飞书群 -> 设置 -> 机器人 -> 添加自定义机器人
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 微信推送 Token
# Server酱: https://sct.ftqq.com 的 SendKey
# PushPlus: https://pushplus.plus 的 Token  
# 企业微信: 机器人 Webhook 完整 URL
# WECHAT_PUSH_TOKEN=your_token_here

# 数据库配置（可选，默认使用 SQLite）
# ------------------------------------------------------------
# DATABASE_URL=sqlite:///../data/papers.db
